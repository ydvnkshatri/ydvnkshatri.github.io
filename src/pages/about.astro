---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title="About — Yadvendra Kshatri"
			description="Engineer and co-founder building production AI systems. Head of AI at Aidetic Software."
		/>
	</head>
	<body>
		<Header />
		<main class="about">
			<header class="page-header">
				<h1>About</h1>
				<p class="subtitle">
					Engineer, co-founder, and Head of AI at <a href="https://www.aaysanalytics.com/">Aays Analytics</a> after aquisition of <a href="https://aidetic.in/">Aidetic Software</a>. Based in Bengaluru.
				</p>
				<p class="contact">
					<a href="mailto:kshatri.yadvendra01@gmail.com">kshatri.yadvendra01@gmail.com</a>
					· <a href="https://www.linkedin.com/in/yadvendra-kshatri-28137a88/">LinkedIn</a>
					· <a href="https://github.com/ydvnkshatri">GitHub</a>
				</p>
			</header>

			<section>
				<p>
					I've spent the last several years building and scaling AI products, from
					NLP research prototypes to production agentic systems running for enterprise
					clients. I co-founded <a href="https://aidetic.in/">Aidetic</a> in 2020 and
					grew it from zero to a 65-person, cross-functional organization, doubling
					revenue year-over-year for three consecutive years before our acquisition.
				</p>
				<p>
					Today I lead pre-sales and forward-deployed engineering across all of our
					AI/ML engagements; embedding with client engineering teams to scope,
					prototype, and ship LLM-powered systems. I care deeply about agent
					architectures, evaluation frameworks, context engineering, and the cost
					and latency tradeoffs that decide whether an LLM project actually makes it
					into production.
				</p>
			</section>

			<section>
				<h2>Experience</h2>

				<div class="role">
					<div class="role-head">
						<h3>Head of AI &amp; Co-founder</h3>
						<h3>Formerly Aidetic Software Now, Aays Analytics</h3>
						<span class="dates">Mar 2020 — Present · Bengaluru</span>
					</div>
					<ul>
						<li>
							Co-founded and scaled Aidetic from 0 to a 65-person cross-functional
							organization; established hiring, engineering, and AI delivery processes
							from scratch.
						</li>
						<li>
							Drove 100% year-over-year revenue growth for three consecutive years and
							ensured a clean handover post-acquisition.
						</li>
						<li>
							Lead pre-sales and forward-deployed engineering on every AI/ML engagement,
							advising on agent architectures, evaluation, context engineering, and cost
							optimization.
						</li>
						<li>
							Lead the strategic Databricks partnership: authored training curricula for
							70+ team members, ran 40+ client workshops and technical deep-dives, and
							shipped reusable docs and sample code (including a migration accelerator
							that speeds competitive migrations by ~40%).
						</li>
						<li>
							Architect and ship production agentic and LLM-powered systems for
							enterprise clients; RAG/retrieval pipelines, tool-use orchestration, and
							evaluation harnesses with ~75% user acceptance, &lt;2.5 min latency for
							~11 LLM calls and tool executions, saving ~1,800 hours/day.
						</li>
					</ul>
				</div>

				<div class="role">
					<div class="role-head">
						<h3>Head of AI &amp; Co-founder · Fabric Analytics</h3>
						<span class="dates">Jul 2023 — Aug 2024 · Bengaluru</span>
					</div>
					<ul>
						<li>Architected the AI and data science engine for a D2C e-commerce platform.</li>
						<li>
							Designed a unified database layer integrating Shopify, Google Ads, and
							Amazon, with RAG and prompt-chaining infrastructure powering text-to-SQL.
						</li>
						<li>
							Built AI-driven anomaly detection, root-cause analysis, and a chat
							assistant tuned for the D2C industry.
						</li>
					</ul>
				</div>

				<div class="role">
					<div class="role-head">
						<h3>NLP Engineer · Nesh</h3>
						<span class="dates">Feb 2021 — Feb 2022 · Bengaluru</span>
					</div>
					<ul>
						<li>
							Built enterprise-grade Q&amp;A systems with domain-specific knowledge
							integration, document processing pipelines, and knowledge graphs from
							glossaries and customer documentation.
						</li>
					</ul>
				</div>

				<div class="role">
					<div class="role-head">
						<h3>Data Analyst · Coviam</h3>
						<span class="dates">Dec 2018 — Mar 2020 · Bengaluru</span>
					</div>
					<ul>
						<li>
							Delivered data science initiatives for a leading Indonesian e-commerce
							platform — real-time license-plate detection, image-based recommendations,
							and CRM/promo analytics.
						</li>
					</ul>
				</div>

				<div class="role">
					<div class="role-head">
						<h3>Data Analytics Associate · ZS Associates</h3>
						<span class="dates">May 2017 — Dec 2018 · Pune</span>
					</div>
					<ul>
						<li>
							Analyzed market research datasets to inform Fortune 500 client decisions;
							modelled consumer behaviour across 6 countries; upgraded VBA tools for
							conjoint analysis.
						</li>
					</ul>
				</div>
			</section>

			<section>
				<h2>Selected projects</h2>

				<div class="project">
					<h3>Agent Factory — Docomo Group retail company</h3>
					<ul>
						<li>
							Designed and shipped an "Agent Factory" platform letting 400 business
							users across 5 domains deploy 10+ LLM-powered agents. Owned agent
							architecture, tool-use design, prompting, and human-in-the-loop guardrails.
						</li>
						<li>
							Ran a data-maturity assessment across 1,200 tables and built retrieval +
							reasoning pipelines that answer complex business questions over
							heterogeneous sources; ~75% user acceptance, &lt;25k tokens per query.
						</li>
						<li>
							Built the platform's evaluation harness; task-level success criteria,
							golden datasets, continuous-eval dashboards, that drove user acceptance
							from ~30% to ~75%.
						</li>
					</ul>
				</div>

				<div class="project">
					<h3>Fintech — Monitoring and Valuation for Investment Funds</h3>
					<ul>
						<li>
							Built models to identify competitors from company descriptions and
							financial data, plus language models recommending companies for investment
							and competitive analysis.
						</li>
						<li>
							Designed pipelines to extract and transform data from financial documents
							for downstream analysis.
						</li>
					</ul>
				</div>

				<div class="project">
					<h3>Sales AI Assistant — Document Search</h3>
					<ul>
						<li>
							Built an AI research assistant ranking and summarizing internal documents
							for oil &amp; gas, banking, and chemical clients; constructed knowledge
							graphs from unstructured data and open repositories.
						</li>
					</ul>
				</div>

				<div class="project">
					<h3>OKR Quality Checker</h3>
					<ul>
						<li>
							Defined evaluation criteria with clients in a data-scarce setting and
							built a labeled benchmark of 500+ examples.
						</li>
						<li>
							Shipped an MLOps pipeline with continuous evaluation, feature and
							performance drift monitoring, and monthly automated retraining with manual
							override.
						</li>
					</ul>
				</div>
			</section>

			<section>
				<h2>Skills</h2>
				<dl class="skills">
					<dt>Deep Learning &amp; NLP</dt>
					<dd>LLMs, RAG, prompt and context engineering, text-to-SQL, conversational AI, evaluation harnesses.</dd>
					<dt>Infrastructure &amp; tools</dt>
					<dd>Python, PyTorch, Azure Databricks, OpenAI, Elasticsearch, Airflow, AWS, Azure, MLOps, Git.</dd>
					<dt>Leadership</dt>
					<dd>Project scoping, team management, client relationships, technical strategy, architecture design.</dd>
					<dt>Analytics</dt>
					<dd>Statistical modelling, CRM analytics, market research, business intelligence.</dd>
				</dl>
			</section>

			<section>
				<h2>Education</h2>
				<p>
					<strong>Indian Institute of Technology (ISM), Dhanbad</strong> — B.Tech, 2013–2017.
				</p>
			</section>
		</main>
		<Footer />
		<style>
			.about {
				width: 760px;
				max-width: calc(100% - 2em);
			}
			.page-header {
				margin-top: 1em;
				margin-bottom: 2em;
			}
			.page-header h1 {
				margin-bottom: 0.2em;
			}
			.subtitle {
				font-size: 1.15em;
				margin-bottom: 0.4em;
			}
			.contact {
				color: rgb(var(--gray));
				font-size: 0.95em;
			}
			section {
				margin-bottom: 2.5em;
			}
			section h2 {
				font-size: 1.953em;
				border-bottom: 1px solid rgb(var(--gray-light));
				padding-bottom: 0.3em;
				margin-bottom: 0.8em;
			}
			.role,
			.project {
				margin-bottom: 1.6em;
			}
			.role h3,
			.project h3 {
				font-size: 1.25em;
				margin-bottom: 0.2em;
			}
			.role-head {
				display: flex;
				flex-wrap: wrap;
				justify-content: space-between;
				align-items: baseline;
				gap: 0.5em;
			}
			.dates {
				color: rgb(var(--gray));
				font-size: 0.9em;
				white-space: nowrap;
			}
			.role ul,
			.project ul {
				margin-top: 0.4em;
				padding-left: 1.2em;
			}
			.role li,
			.project li {
				margin-bottom: 0.5em;
			}
			.skills {
				display: grid;
				grid-template-columns: max-content 1fr;
				gap: 0.5em 1.2em;
			}
			.skills dt {
				font-weight: 700;
				color: rgb(var(--black));
			}
			.skills dd {
				margin: 0;
			}
			@media (max-width: 600px) {
				.skills {
					grid-template-columns: 1fr;
					gap: 0.2em;
				}
				.skills dd {
					margin-bottom: 0.6em;
				}
			}
		</style>
	</body>
</html>
